{
  "name": "@xpayr/node-sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for the XPayr Merchant API.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": ["src", "index.d.ts", "README.md", "LICENSE"],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "check": "node --check src/client.js && node --check src/webhooks.js && npm test",
    "prepack": "npm run check"
  },
  "engines": {"node": ">=18"},
  "keywords": ["xpayr", "crypto-payments", "payment-gateway", "usdt", "usdc", "webhooks"],
  "license": "MIT",
  "repository": {"type": "git", "url": "git+https://github.com/xpayrcom/xpayr-node-sdk.git"},
  "homepage": "https://xpayr.com/developers"
}
